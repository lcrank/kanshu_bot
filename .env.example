# ─── Telegram Bot Token ───────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── OpenRouter API Key ───────────────────────────────────────────────────────
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── OpenRouter Model ─────────────────────────────────────────────────────────
# Supports 300+ models. See: https://openrouter.ai/models
# Popular options:
#   openai/gpt-4o-mini        — fastest, cheapest ($0.15/M tokens)
#   openai/gpt-4o             — best quality, slower
#   anthropic/claude-sonnet-4 — best for creative scripts
#   google/gemini-2.0-flash   — great speed/quality balance
#   meta-llama/llama-3.3-70b  — open-source alternative
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── OpenRouter Identity (optional) ──────────────────────────────────────────
# Lets model providers see where requests come from — no personal data
OPENROUTER_REFERER=https://github.com/lara-sk-bot
OPENROUTER_TITLE=Lara SK Reels Bot

# ─── LinkedIn Image Generation (optional) ────────────────────────────────────
# Set to an image model to enable AI-generated images for LinkedIn posts.
# Leave blank to skip image generation (text-only posts).
# Popular options:
#   black-forest-labs/flux-dev              — fast, high quality (recommended)
#   black-forest-labs/flux-schnell          — fastest, still good
#   openai/dall-e-3                         — best quality, slower, more expensive
#   stabilityai/stable-diffusion-3.5-large  — good quality, open-source
LINKEDIN_IMAGE_MODEL=black-forest-labs/flux-dev
# Image size: 1024x1024, 1024x1792, or 1792x1024
LINKEDIN_IMAGE_SIZE=1024x1024
